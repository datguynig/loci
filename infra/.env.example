# MinIO credentials — use a strong random password (64+ chars)
MINIO_ROOT_USER=loci-admin
MINIO_ROOT_PASSWORD=change-me-to-a-very-long-random-password

# Internal URL used by the presign-api container to talk to MinIO (Docker service name)
MINIO_ENDPOINT=http://minio:9000

# Public-facing MinIO URL (used in presigned URLs — must match Traefik domain)
MINIO_PUBLIC_URL=https://minio.loci.app

# Clerk JWKS endpoint — replace with your Clerk instance URL
# Found in Clerk dashboard → API Keys → Advanced → JWKS URL
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# Allowed origins for CORS (comma-separated, no spaces)
CORS_ORIGINS=https://loci.app,http://localhost:5173

# Port the Bun API listens on inside its container
PORT=3100

# MinIO CORS — allows browsers to PUT/GET directly to MinIO via presigned URLs
MINIO_API_CORS_ALLOW_ORIGIN=https://loci.app,http://localhost:5173

# Copy to .env.local and fill in values (.env.local is gitignored).

# ── Clerk (required) ─────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=

# ── Supabase (required) ─────────────────────────────────────────────────────
# Postgres + auth session. Edge Functions (ai-study, create-trial, create-checkout,
# create-portal, stripe-webhook) use this URL + anon key from the client where applicable.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Object storage (required) ───────────────────────────────────────────────
# Presign API for EPUB upload/download; public base URL for cover images (MinIO or compatible).
# Example (hosted): https://api-storage.loci.app and https://minio.loci.app
VITE_STORAGE_API_URL=
VITE_MINIO_PUBLIC_URL=

# ── ElevenLabs TTS (optional) ───────────────────────────────────────────────
# Set to enable Loci Narration (Reader/Scholar tiers). Leave blank to use browser Web Speech only.
# Production: prefer VITE_ELEVENLABS_PROXY_URL so the provider API key stays server-side.
# Local/dev only: VITE_ELEVENLABS_API_KEY can point at the key (still never commit .env.local).
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_PROXY_URL=

# ── Testing (optional) ───────────────────────────────────────────────────────
# Playwright sets this to "true". When true, the app uses the minimal E2E shell and skips
# first-run UI. Use false or omit for normal development.
VITE_E2E_TEST=false

# ── Stripe / Subscriptions ─────────────────────────────────────────────────
# These secrets live on the SERVER (Supabase Dashboard → Edge Functions → Secrets), NOT here.
# Keys required on Supabase:
#   STRIPE_SECRET_KEY
#   STRIPE_WEBHOOK_SECRET
#   STRIPE_READER_MONTHLY_PRICE_ID
#   STRIPE_READER_ANNUAL_PRICE_ID
#   STRIPE_SCHOLAR_MONTHLY_PRICE_ID
#   STRIPE_SCHOLAR_ANNUAL_PRICE_ID
#   APP_URL=https://your-production-domain.com   ← REQUIRED for checkout/portal redirect URLs
#
# Also required in Clerk Dashboard → JWT Templates: a template named exactly "supabase"
# (HS256, signed with your Supabase JWT secret). Without it all Edge Function calls return 401.

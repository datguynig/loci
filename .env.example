# ── Supabase (database + auth only — storage has moved to MinIO) ──────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Clerk ─────────────────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=

# ── MinIO Storage (self-hosted on VPS) ────────────────────────────────────────
# URL of the Bun presign-api (issues upload/download/delete presigned URLs)
VITE_STORAGE_API_URL=https://api-storage.loci.app
# Public-facing MinIO URL (used for permanent cover image URLs)
VITE_MINIO_PUBLIC_URL=https://minio.loci.app

# ── ElevenLabs TTS (optional) ─────────────────────────────────────────────────
# Set ONE of the following (API key for direct access, proxy URL for production).
# Leave both blank to use browser Web Speech voices only.
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_PROXY_URL=

# ── Clerk ─────────────────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=

# ── Supabase ───────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── MinIO Storage (self-hosted on VPS) ────────────────────────────────────────
# URL of the Bun presign-api (issues upload/download/delete presigned URLs)
VITE_STORAGE_API_URL=https://api-storage.loci.app
# Public-facing MinIO URL (used for permanent cover image URLs)
VITE_MINIO_PUBLIC_URL=https://minio.loci.app

# ── ElevenLabs TTS (optional) ─────────────────────────────────────────────────
# Set to enable Loci Narration (Reader/Scholar tiers). Leave blank to use
# browser Web Speech voices only.
# IMPORTANT: The ElevenLabs API key must live server-side — never put it here.
VITE_ELEVENLABS_PROXY_URL=

# ── Testing ────────────────────────────────────────────────────────────────────
# Set to "true" to suppress first-run UI (onboarding, reader tour) in E2E tests
VITE_E2E_TEST=false

# ── Stripe (subscriptions) ────────────────────────────────────────────────────
# Stripe env vars are NOT set here — they go in the Supabase edge function
# environment (dashboard → Edge Functions → Secrets). See README for the full
# list: STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_*_PRICE_ID, etc.
